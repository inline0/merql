{
    "name": "inline0/merql",
    "description": "Pure PHP three-way database merge with column-level conflict resolution",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "Merql\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Merql\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:unit": "phpunit --testsuite=unit",
        "test": "phpunit",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    }
}
