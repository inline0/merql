#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use Merql\Tests\Oracle\OracleCapture;
use Merql\Tests\Oracle\ScenarioComparator;
use Merql\Tests\Oracle\ScenarioRepository;

$name = $argv[1] ?? null;
if ($name === null) {
    fprintf(STDERR, "Usage: compare <scenario-name>\n");
    exit(1);
}

$repo = new ScenarioRepository();
$scenario = $repo->find($name);

if ($scenario === null) {
    fprintf(STDERR, "Scenario '%s' not found\n", $name);
    exit(1);
}

$result = OracleCapture::compute($scenario);
$comparison = ScenarioComparator::compare($result['mergeResult'], $scenario['config']);

if ($comparison['pass']) {
    echo "PASS  {$name}\n";
    exit(0);
}

echo "FAIL  {$name}\n";
foreach ($comparison['failures'] as $failure) {
    echo "  - {$failure}\n";
}
exit(1);
